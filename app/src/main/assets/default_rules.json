  "code_extraction": {
    "express": {
      "trigger_keywords": ["取件码", "取性码", "请凭", "靖凭"],
      "patterns": [
        { "id": "express_3segment", "regex": "([A-Z0-9]+-[A-Z0-9]+-[A-Z0-9]+)", "priority": 1, "description": "三段式连字符（A-2-7261）", "weight_multiplier": 20 },
        { "id": "express_2segment", "regex": "([A-Z]{1,3}[0-9]{0,3}-[0-9]{3,8}|[A-Z0-9]{1,4}-[A-Z0-9]{3,8})", "priority": 2, "description": "两段式连字符（ZT-20001）", "weight_multiplier": 20 },
        { "id": "express_pure_number", "regex": "(?<![0-9])([0-9]{4,8})(?![0-9])", "priority": 3, "description": "纯数字 4-8 位（39359）", "weight_multiplier": 1 },
        { "id": "express_alphanum", "regex": "([A-Z]{1,3}[0-9]{4,8}|[A-Z][0-9]{6,10})", "priority": 4, "description": "字母数字混合（ZT20001）", "weight_multiplier": 5 },
        { "id": "express_generic", "regex": "([A-Z0-9-]{3,12})", "priority": 5, "description": "通用模式", "weight_multiplier": 1 }
      ],
      "fallback_pattern": {
        "regex": "(?<![a-zA-Z0-9-])([0-9]{4,8}|[A-Z0-9]+-[A-Z0-9]+-[A-Z0-9]+|[A-Z]{1,3}[0-9]{0,3}-[0-9]{3,8}|[A-Z0-9]{1,4}-[A-Z0-9]{3,8}|[A-Z]{1,3}[0-9]{4,8}|[A-Z][0-9]{6,10}|[A-Z0-9][A-Z0-9-]{2,11})(?![a-zA-Z0-9-])",
        "requires_trigger": true
      }
    },
    "food": {
      "trigger_keywords": ["取餐", "取茶", "验证码", "券码", "订单", "准备完毕", "领取", "取单", "取货"],
      "hint_keywords": ["取单码", "取单号", "取餐号", "取餐码", "取茶号", "取货码", "券码", "订单号", "取性码", "取養号"],
      "queue_keywords": ["叫号", "取号", "过号", "排队", "迎宾台", "到店就餐", "还需等待", "桌安排"],
      "queue_threshold": 2,
      "patterns": {
        "queue_patterns": [
          { "id": "queue_desk_code", "regex": "(小桌|中桌|大桌)\\s*([A-Z]{1,2}\\d{1,3}|\\d{1,3}[A-Z]{1,2})", "description": "桌型+码（小桌A3）", "code_length_min": 2, "code_length_max": 5, "require_mixed": true },
          { "id": "queue_plain_code", "regex": "([A-Z]{1,2}\\d{1,3}|\\d{1,3}[A-Z]{1,2})(?=[A-Z]{0,2}号|\\s*(?:号|桌|台|单))", "description": "纯号位码（A3号）", "code_length_min": 2, "code_length_max": 5, "require_mixed": true }
        ],
        "slogan_pattern": { "id": "slogan_code", "regex": "([A-Z][A-Z0-9]{2,9}[.．][\\u4e00-\\u9fa5A-Za-z0-9]{2,24})", "priority": 1, "description": "口令型（M707.你的脚步有力量）", "weight_multiplier": 1 },
        "keyword_pattern": { "id": "keyword_code", "forward_regex": "取单码|取单号|取餐号|取餐码|取茶号|取货码|券码|订单号|取性码|取養号[:：]?([A-Z0-9]{3,10})", "reverse_regex": "([A-Z0-9]{3,10})[:：]?(?:取单码|取单号|取餐号|取餐码|取茶号|取货码|券码|订单号|取性码|取養号)" },
        "fallback_pattern": { "id": "food_fallback", "regex": "(?<![a-zA-Z0-9])([A-Z0-9]{3,10})(?![a-zA-Z0-9])", "priority": 5, "description": "全文兜底", "weight_multiplier": 1 }
      },
      "starbucks_pattern": { "regex": "(\\d{1,3}[.．][\\u4e00-\\u9fa5]{2,10})", "trigger_keywords": ["啡快口令"], "trigger_brand": "星巴克", "description": "星巴克啡快口令（17.超常发挥）" }
    }
  },

